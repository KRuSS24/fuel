<changeSet id="2" author="KRuSS24">
    <createTable tableName="fuel_cards">
        <column name="id" type="BIGINT">
            <constraints primaryKey="true"/>
        </column>
        <column name="card_nr" type="VARCHAR(50)">
            <constraints nullable="false"/>
        </column>
        <column name="pin" type="VARCHAR(4)">
            <constraints nullable="false"/>
        </column>
        <column name="exp_date" type="DATE"/>
        <column name="truck_nr" type="VARCHAR(10)"/>
        <column name="petrol_station_ref" type="BIGINT"/>
    </createTable>

    <addForeignKeyConstraint baseTableName="fuel_cards"
                             baseColumnNames="petrol_station_ref"
                             constraintName="petrol_station_ref"
                             referencedTableName="petrol_stations"
                             referencedColumnNames="id"/>

</changeSet>

